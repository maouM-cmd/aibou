# ふだんどおりOllamaでローカル利用するだけなら、このファイルの設定は一切不要です。
# （AIBOU_PROVIDER未設定 = 既定の "ollama" のまま動きます）

# --- Qwen Cloudハッカソン提出用（provider="qwen"で動かす場合のみ設定） ---

# "ollama"（既定・ローカル） または "qwen"（Qwen Cloud経由）
AIBOU_PROVIDER=qwen

# Qwen Cloud (home.qwencloud.com) で発行したAPIキー
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 使用するQwenモデル名。実装時点のサンプル値。Qwen Cloudコンソールで最新の利用可能モデル名を要確認
AIBOU_QWEN_MODEL=qwen3.7-plus

# 通常は変更不要（OpenAI互換のDashScopeエンドポイント）
AIBOU_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- サーバーのホスト/ポート（Dockerコンテナ内ではAIBOU_HOST=0.0.0.0が必要） ---
AIBOU_HOST=127.0.0.1
AIBOU_PORT=8000
